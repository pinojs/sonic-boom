  "author": "Matteo Collina <hello@matteocollina.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pinojs/sonic-boom/issues"
  },
  "homepage": "https://github.com/pinojs/sonic-boom#readme",
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.0.0",
    "@types/node": "^25.0.3",
    "borp": "^1.0.0",
    "eslint": "^10.2.1",
    "fastbench": "^1.0.1",
    "neostandard": "^0.13.0",
    "proxyquire": "^2.1.3",
    "tsd": "^0.33.0",
    "typescript": "~6.0.2"
  },
  "dependencies": {
    "atomic-sleep": "^1.0.0"
  },
  "tsd": {
    "directory": "./types"
  }
