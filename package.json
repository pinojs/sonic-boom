{
  "name": "sonic-boom",
  "version": "5.0.0",
  "description": "Extremely fast utf8 only stream implementation",
  "main": "index.js",
  "type": "commonjs",
  "types": "types/index.d.ts",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "npm run test:types && npm run lint && npm run test:unit",
